# CareOS Production Environment
# DO NOT commit real secrets — use CI/CD secrets or vault
# All secrets injected at deploy time via environment or secrets manager

# ── Database ──────────────────────────────────────
DATABASE_URL=            # from secrets (PostgreSQL connection string)

AIDBOX_URL=              # from secrets (production FHIR server)
AIDBOX_CLIENT_ID=        # from secrets
AIDBOX_CLIENT_SECRET=    # from secrets

REDIS_URL=               # from secrets (production Redis)

# ── Auth ──────────────────────────────────────────
JWT_PRIVATE_KEY=         # from secrets (RS256 PEM, 4096-bit)
JWT_PUBLIC_KEY=          # from secrets (RS256 PEM)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ── Integrations ──────────────────────────────────
STRIPE_SECRET_KEY=       # sk_live_... from secrets
STRIPE_WEBHOOK_SECRET=   # from secrets
STRIPE_MEMBERSHIP_PRICE_ID=  # from secrets

TWILIO_ACCOUNT_SID=      # from secrets
TWILIO_AUTH_TOKEN=        # from secrets
TWILIO_PHONE_NUMBER=     # from secrets

SENDGRID_API_KEY=        # from secrets
SENDGRID_FROM_EMAIL=hello@co-op.care

GOOGLE_MAPS_API_KEY=     # from secrets

# ── Application ───────────────────────────────────
NODE_ENV=production
PORT=3001
FRONTEND_URL=https://app.co-op.care
CORS_ORIGINS=https://app.co-op.care

# ── VAPID (Web Push) ─────────────────────────────
VAPID_PUBLIC_KEY=        # from secrets
VAPID_PRIVATE_KEY=       # from secrets
VAPID_MAILTO=mailto:blaine@co-op.care
