# co-op.care (CareOS) Environment Variables
# Copy to .env and fill in values
#
# Quick start:
#   cp .env.example .env
#   npm run docker:infra   # start databases
#   npm run dev             # frontend (port 5173)
#   npm run dev:server      # backend  (port 3001)
#
# Generate JWT keys:   npx tsx scripts/generate-jwt-keys.ts
# Generate VAPID keys: npx web-push generate-vapid-keys

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://careos:careos_dev@localhost:5432/careos

AIDBOX_URL=http://localhost:8888
AIDBOX_CLIENT_ID=root
AIDBOX_CLIENT_SECRET=secret

REDIS_URL=redis://localhost:6379
REDIS_PASSWORD=               # REQUIRED in production — set in docker-compose.production.yml

# ============================================================
# AUTH
# ============================================================
JWT_PRIVATE_KEY=   # RS256 private key (PEM)
JWT_PUBLIC_KEY=    # RS256 public key (PEM)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================
# INTEGRATIONS
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MEMBERSHIP_PRICE_ID=price_...

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@co-op.care

GOOGLE_MAPS_API_KEY=

DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

CHECKR_API_KEY=

# ============================================================
# FIREBASE AUTH (Google sign-in)
# ============================================================
# Create a Firebase project at https://console.firebase.google.com
# Enable Authentication → Sign-in method → Google
# Add your Vercel domain to Authorized domains
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# ============================================================
# AI — Sage LLM (Claude Sonnet)
# ============================================================
ANTHROPIC_API_KEY=             # Required for Claude-powered Sage responses
                               # Get key at: https://console.anthropic.com/settings/keys

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ============================================================
# VAPID KEYS (Web Push)
# Generate with: npx web-push generate-vapid-keys
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:blaine@co-op.care
VITE_VAPID_PUBLIC_KEY=         # Same as VAPID_PUBLIC_KEY — exposed to browser for push subscription

# ============================================================
# MONITORING (optional — leave blank to disable)
# ============================================================
SENTRY_DSN=                    # Server-side Sentry DSN
VITE_SENTRY_DSN=               # Client-side Sentry DSN (exposed to browser)

# ============================================================
# PRODUCTION DEPLOYMENT NOTES
# ============================================================
# 1. Generate RS256 JWT keys (4096-bit):
#      openssl genrsa -out jwt-private.pem 4096
#      openssl rsa -in jwt-private.pem -pubout -out jwt-public.pem
#    Then paste PEM contents into JWT_PRIVATE_KEY and JWT_PUBLIC_KEY
#
# 2. Stripe: Use sk_live_ key (not sk_test_) and set up webhook at
#    https://yourdomain.com/api/v1/payment/webhook
#
# 3. Redis: ALWAYS set REDIS_PASSWORD in production
#
# 4. Docker production: docker compose -f docker-compose.production.yml up -d
#    Requires Caddyfile in project root for TLS termination
