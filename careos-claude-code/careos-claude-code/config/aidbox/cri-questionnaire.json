{
  "resourceType": "Questionnaire",
  "id": "cri-assessment",
  "url": "https://co-op.care/fhir/Questionnaire/cri-assessment",
  "version": "1.0.0",
  "name": "CareReadinessIndex",
  "title": "Care Readiness Index (CRI)",
  "status": "active",
  "date": "2026-03-01",
  "publisher": "co-op.care",
  "description": "14-factor clinician-administered assessment. Raw score range 14.4-72.0. Requires Medical Director review and sign-off.",
  "purpose": "Assess care recipient readiness and caregiver capacity via structured clinical interview. Used for LMN generation and care plan creation.",
  "subjectType": ["Patient"],
  "item": [
    {
      "linkId": "cri-1",
      "text": "Cognitive Status",
      "definition": "Assessed cognitive function level using standardized screening",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-2",
      "text": "Functional Mobility",
      "definition": "Ability to move independently and perform transfers",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-3",
      "text": "ADL Independence",
      "definition": "Ability to perform activities of daily living independently",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-4",
      "text": "IADL Capacity",
      "definition": "Ability to perform instrumental activities (cooking, finances, transport)",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-5",
      "text": "Medication Complexity",
      "definition": "Number and complexity of medications requiring management",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-6",
