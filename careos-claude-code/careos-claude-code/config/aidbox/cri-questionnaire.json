      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-7",
      "text": "Fall Risk",
      "definition": "History and risk factors for falls",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-8",
      "text": "Nutritional Status",
      "definition": "Nutritional adequacy and meal preparation needs",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
