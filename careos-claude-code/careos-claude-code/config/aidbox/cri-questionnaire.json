      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.0 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.0 }
      ]
    },
    {
      "linkId": "cri-13",
      "text": "Financial Resources",
      "definition": "Financial capacity for ongoing care needs",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.03 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.14 }
      ]
    },
    {
      "linkId": "cri-14",
      "text": "Care Plan Adherence History",
      "definition": "Track record of following recommended care plans",
      "type": "decimal",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 1.03 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 5.14 }
      ]
    },
    {
      "linkId": "cri-total",
      "text": "Total CRI Raw Score",
      "type": "decimal",
      "readOnly": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueDecimal": 14.4 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueDecimal": 72.0 }
      ]
    },
    {
      "linkId": "cri-md-review",
      "text": "Medical Director Review",
      "type": "group",
      "item": [
        {
