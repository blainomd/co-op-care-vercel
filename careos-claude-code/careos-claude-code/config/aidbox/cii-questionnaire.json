{
  "resourceType": "Questionnaire",
  "id": "cii-assessment",
  "url": "https://co-op.care/fhir/Questionnaire/cii-assessment",
  "version": "1.0.0",
  "name": "CaregiverIntensityIndex",
  "title": "Caregiver Intensity Index (CII)",
  "status": "active",
  "date": "2026-03-01",
  "publisher": "co-op.care",
  "description": "12-dimension assessment measuring caregiver impact intensity. Each dimension scored 1-10. Total score /120 classified into Green (0-40), Yellow (41-79), Red (80-120) zones.",
  "purpose": "Quantify caregiving burden across 12 domains to match caregivers with appropriate community support resources.",
  "subjectType": ["Patient"],
  "item": [
    {
      "linkId": "cii-1",
      "text": "Physical Care Demands",
      "definition": "How much hands-on physical help does your loved one need?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-2",
      "text": "Cognitive Supervision",
      "definition": "How much do you need to supervise or redirect their daily activities?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-3",
      "text": "Emotional Labor",
      "definition": "How emotionally draining is the caregiving experience?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-4",
      "text": "Financial Management",
      "definition": "How much of their financial affairs do you manage?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-5",
      "text": "Medical Coordination",
      "definition": "How much medical appointment and medication coordination do you handle?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-6",
      "text": "Transportation",
      "definition": "How much driving or transport arranging do you do for them?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-7",
      "text": "Household Management",
      "definition": "How much household work falls to you because of caregiving?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-8",
      "text": "Social Isolation Impact",
      "definition": "How much has caregiving affected your own social life?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-9",
      "text": "Sleep Disruption",
      "definition": "How much does caregiving disrupt your sleep?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-10",
      "text": "Work Impact",
      "definition": "How much has caregiving affected your work or career?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-11",
      "text": "Physical Health Impact",
      "definition": "How much has caregiving affected your own physical health?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-12",
      "text": "Financial Strain",
      "definition": "How much financial pressure does caregiving create for you?",
      "type": "integer",
      "required": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 1 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 10 }
      ]
    },
    {
      "linkId": "cii-total",
      "text": "Total CII Score",
      "type": "integer",
      "readOnly": true,
      "extension": [
        { "url": "http://hl7.org/fhir/StructureDefinition/minValue", "valueInteger": 12 },
        { "url": "http://hl7.org/fhir/StructureDefinition/maxValue", "valueInteger": 120 }
      ]
    },
    {
      "linkId": "cii-zone",
      "text": "CII Zone Classification",
      "type": "choice",
      "readOnly": true,
      "answerOption": [
        { "valueCoding": { "system": "https://co-op.care/fhir/CodeSystem/cii-zones", "code": "GREEN", "display": "Green (0-40)" } },
        { "valueCoding": { "system": "https://co-op.care/fhir/CodeSystem/cii-zones", "code": "YELLOW", "display": "Yellow (41-79)" } },
        { "valueCoding": { "system": "https://co-op.care/fhir/CodeSystem/cii-zones", "code": "RED", "display": "Red (80-120)" } }
      ]
    }
  ]
}
