# CareOS Environment Variables
# Copy to .env and fill in values

# ============================================================
# DATABASE
# ============================================================
DATABASE_URL=postgresql://careos:careos_dev@localhost:5432/careos

AIDBOX_URL=http://localhost:8888
AIDBOX_CLIENT_ID=root
AIDBOX_CLIENT_SECRET=secret

REDIS_URL=redis://localhost:6379

# ============================================================
# AUTH
# ============================================================
JWT_PRIVATE_KEY=   # RS256 private key (PEM)
JWT_PUBLIC_KEY=    # RS256 public key (PEM)
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ============================================================
# INTEGRATIONS
# ============================================================
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_MEMBERSHIP_PRICE_ID=price_...

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_PHONE_NUMBER=

SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=hello@co-op.care

GOOGLE_MAPS_API_KEY=

DOCUSIGN_INTEGRATION_KEY=
DOCUSIGN_SECRET_KEY=
DOCUSIGN_ACCOUNT_ID=

ZOOM_CLIENT_ID=
ZOOM_CLIENT_SECRET=

CHECKR_API_KEY=

# ============================================================
# APPLICATION
# ============================================================
NODE_ENV=development
PORT=3001
FRONTEND_URL=http://localhost:5173
CORS_ORIGINS=http://localhost:5173

# ============================================================
# VAPID KEYS (Web Push)
# ============================================================
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_MAILTO=mailto:blaine@co-op.care
